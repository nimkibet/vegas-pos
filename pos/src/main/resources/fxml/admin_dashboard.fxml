<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.pos.controller.AdminDashboardController"
            stylesheets="@../css/style.css" styleClass="root">
    
    <!-- Top Header -->
    <top>
        <HBox styleClass="glass-header" alignment="CENTER_LEFT" maxWidth="Infinity">
            <HBox spacing="15" alignment="CENTER_LEFT">
                <StackPane style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 8;">
                    <Label text="A" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #064e3b;" />
                </StackPane>
                <VBox alignment="CENTER_LEFT">
                    <Label text="ADMIN PORTAL" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: white;" />
                    <Label text="Vegas POS Management" style="-fx-font-size: 10; -fx-text-fill: rgba(255,255,255,0.7); -fx-letter-spacing: 2;" />
                </VBox>
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <HBox spacing="20" alignment="CENTER_RIGHT">
                <Button fx:id="themeToggleButton" text="🌙 Dark Mode" onAction="#toggleTheme" styleClass="btn-ghost" style="-fx-text-fill: white; -fx-border-color: rgba(255,255,255,0.3);" />
                <Button text="A± Text Size" onAction="#toggleTextSize" styleClass="nav-button" style="-fx-text-fill: white; -fx-border-color: rgba(255,255,255,0.3);" />
                <Label fx:id="userLabel" text="System Admin" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: white;" />
                <Button text="Launch Terminal" onAction="#switchToPOS" styleClass="btn-primary" style="-fx-background-color: #10b981; -fx-text-fill: white;" />
                <Button text="Logout" onAction="#handleLogout" styleClass="btn-danger" />
            </HBox>
        </HBox>
    </top>
    
    <!-- Left Navigation Menu -->
    <left>
        <VBox styleClass="sidebar-glass" prefWidth="250" VBox.vgrow="ALWAYS">
            <VBox spacing="5" VBox.vgrow="ALWAYS" style="-fx-padding: 20 15;">
                <!-- Category: Inventory Management -->
                <Label text="INVENTORY CONTROL" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #94a3b8; -fx-padding: 10 10 5 10;" />
                <Button fx:id="navProductMgmt" text="📦 Products" onAction="#showProductManagement" 
                        styleClass="nav-button" onMouseEntered="#onNavHover" onMouseExited="#onNavExit" maxWidth="Infinity" />
                <Button fx:id="navStockVerify" text="🔍 Stock Check" onAction="#showStockVerification" 
                        styleClass="nav-button" onMouseEntered="#onNavHover" onMouseExited="#onNavExit" maxWidth="Infinity" />
                <Button fx:id="navStockIn" text="📥 Restock" onAction="#showStockIn"
                        styleClass="nav-button" onMouseEntered="#onNavHover" onMouseExited="#onNavExit" maxWidth="Infinity" />
                
                <Region prefHeight="15" />
                <Separator style="-fx-opacity: 0.1;" />

                <!-- Category: Store Operations -->
                <Label text="OPERATIONS" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #94a3b8; -fx-padding: 10 10 5 10;" />
                <Button fx:id="navApprovalQueue" text="✓ Approvals" onAction="#showApprovalQueue" 
                        styleClass="nav-button" onMouseEntered="#onNavHover" onMouseExited="#onNavExit" maxWidth="Infinity" />
                <Button fx:id="navUsers" text="👥 Team" onAction="#showUserManagement" 
                        styleClass="nav-button" onMouseEntered="#onNavHover" onMouseExited="#onNavExit" maxWidth="Infinity" />
                
                <Region prefHeight="15" />
                <Separator style="-fx-opacity: 0.1;" />

                <!-- Category: Finance & Analytics -->
                <Label text="BUSINESS INSIGHTS" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #94a3b8; -fx-padding: 10 10 5 10;" />
                <Button fx:id="navAnalytics" text="📊 Performance" onAction="#showAnalytics" 
                        styleClass="nav-button" onMouseEntered="#onNavHover" onMouseExited="#onNavExit" maxWidth="Infinity" />
                <Button fx:id="navDebtors" text="💳 Debtors" onAction="#showDebtors" 
                        styleClass="nav-button" onMouseEntered="#onNavHover" onMouseExited="#onNavExit" maxWidth="Infinity" />
            </VBox>
            
            <!-- Quick Stats Sidebar Widget -->
            <VBox style="-fx-padding: 20; -fx-background-color: #f1f5f9; -fx-background-radius: 0 0 0 0;">
                <Label text="System Health" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #475569;" />
                <VBox spacing="8" style="-fx-padding: 12 0 0 0;">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Circle radius="3" fill="#10b981" />
                        <Label fx:id="totalProductsLabel" text="Products: 0" style="-fx-font-size: 11; -fx-text-fill: #64748b;" />
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Circle radius="3" fill="#f59e0b" />
                        <Label fx:id="pendingApprovalsLabel" text="Pending: 0" style="-fx-font-size: 11; -fx-text-fill: #64748b;" />
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Circle radius="3" fill="#ef4444" />
                        <Label fx:id="lowStockLabel" text="Low Stock: 0" style="-fx-font-size: 11; -fx-text-fill: #64748b;" />
                    </HBox>
                </VBox>
            </VBox>
        </VBox>
    </left>
    
    <!-- Center Content Area -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: transparent; -fx-padding: 20;">
            <!-- Active View Container -->
            <VBox spacing="20">
                <fx:include fx:id="inventoryManagement" source="inventory_management.fxml" visible="true" managed="true" />
                
                <!-- Hidden views managed by controller -->
                <fx:include fx:id="stockInForm" source="stock_in_form.fxml" visible="false" managed="false"/>
                <fx:include fx:id="userManagementView" source="user_management.fxml" visible="false" managed="false" />
                <fx:include fx:id="debtorsView" source="admin_debtors.fxml" visible="false" managed="false" />
                
                <!-- Verification View -->
                <VBox fx:id="stockVerifyView" spacing="20" visible="false" managed="false">
                    <HBox alignment="CENTER_LEFT">
                        <VBox>
                            <Label text="Stock Verification" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />
                            <Label text="Audit and adjust inventory levels" style="-fx-text-fill: #64748b;" />
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox spacing="10">
                            <Button text="Low Stock Only" onAction="#showLowStock" styleClass="btn-ghost" />
                            <Button text="Show All" onAction="#showAllStock" styleClass="btn-ghost" />
                        </HBox>
                    </HBox>
                    
                    <VBox styleClass="card" VBox.vgrow="ALWAYS" style="-fx-padding: 0;">
                        <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 15;">
                            <TextField fx:id="stockSearchField" promptText="Scan or search products..." HBox.hgrow="ALWAYS" prefHeight="40" />
                            <Button text="Search" onAction="#handleStockSearch" styleClass="btn-primary" prefHeight="40" />
                        </HBox>
                        <TableView fx:id="stockTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                            <columns>
                                <TableColumn text="Barcode" fx:id="colStockBarcode" />
                                <TableColumn text="Product Name" fx:id="colStockName" prefWidth="250" />
                                <TableColumn text="Category" fx:id="colStockCategory" />
                                <TableColumn text="In Stock" fx:id="colCurrentStock" />
                                <TableColumn text="Min Level" fx:id="colMinLevel" />
                                <TableColumn text="Price" fx:id="colStockRetail" />
                            </columns>
                        </TableView>
                    </VBox>
                    
                    <HBox styleClass="card" spacing="20" alignment="CENTER_LEFT">
                        <Label text="Selected:" style="-fx-text-fill: #64748b;" />
                        <Label fx:id="selectedProductLabel" text="None" style="-fx-font-weight: bold; -fx-font-size: 14;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <TextField fx:id="newStockField" promptText="New Count" prefWidth="120" prefHeight="40" />
                        <Button text="Confirm Adjustment" onAction="#handleStockAdjustment" styleClass="btn-warning" prefHeight="40" />
                    </HBox>
                </VBox>
                
                <!-- Approval View -->
                <VBox fx:id="approvalQueueView" spacing="20" visible="false" managed="false">
                    <VBox>
                        <Label text="Approval Queue" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />
                        <Label text="Review items added by attendants" style="-fx-text-fill: #64748b;" />
                    </VBox>
                    
                    <VBox styleClass="card" VBox.vgrow="ALWAYS" style="-fx-padding: 0;">
                        <TableView fx:id="approvalTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                            <columns>
                                <TableColumn text="Barcode" fx:id="colApprovalBarcode" />
                                <TableColumn text="Product" fx:id="colApprovalName" prefWidth="200" />
                                <TableColumn text="Category" fx:id="colApprovalCategory" />
                                <TableColumn text="Retail" fx:id="colApprovalRetail" />
                                <TableColumn text="Wholesale" fx:id="colApprovalWholesale" />
                                <TableColumn text="Stock" fx:id="colApprovalStock" />
                                <TableColumn text="Date" fx:id="colApprovalDate" />
                            </columns>
                        </TableView>
                        <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 15;">
                            <Button text="Reject" onAction="#handleRejectItem" styleClass="btn-danger" />
                            <Button text="Approve Selected" onAction="#handleApproveItem" styleClass="btn-primary" />
                        </HBox>
                    </VBox>
                </VBox>
                
                <!-- Analytics View -->
                <VBox fx:id="analyticsView" spacing="20" visible="false" managed="false">
                    <Label text="Performance Analytics" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />
                    
                    <HBox spacing="20">
                        <VBox styleClass="card" HBox.hgrow="ALWAYS" alignment="CENTER">
                            <Label text="TODAY'S REVENUE" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #64748b;" />
                            <Label fx:id="todayRevenueLabel" text="KSh 0.00" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #10b981;" />
                        </VBox>
                        <VBox styleClass="card" HBox.hgrow="ALWAYS" alignment="CENTER">
                            <Label text="TRANSACTIONS" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #64748b;" />
                            <Label fx:id="todayTransactionsLabel" text="0" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />
                        </VBox>
                        <VBox styleClass="card" HBox.hgrow="ALWAYS" alignment="CENTER">
                            <Label text="NET PROFIT" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #64748b;" />
                            <Label fx:id="netProfitLabel" text="KSh 0.00" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #3b82f6;" />
                        </VBox>
                    </HBox>
                    
                    <HBox spacing="20" VBox.vgrow="ALWAYS">
                        <VBox styleClass="card" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 10 0;">
                                <Label text="Revenue Trend" style="-fx-font-weight: bold; -fx-font-size: 16px;" HBox.hgrow="ALWAYS" />
                                <Region HBox.hgrow="ALWAYS" />
                                <ComboBox fx:id="timeframeSelector" prefWidth="150" />
                            </HBox>
                            <LineChart fx:id="revenueChart" legendSide="BOTTOM">
                                <xAxis><CategoryAxis animated="false" /></xAxis>
                                <yAxis><NumberAxis /></yAxis>
                            </LineChart>
                        </VBox>
                        <VBox styleClass="card" prefWidth="350">
                            <Label text="Top Selling Categories" style="-fx-font-weight: bold; -fx-padding: 0 0 10 0;" />
                            <PieChart fx:id="topItemsChart" labelsVisible="false" />
                            <ListView fx:id="topCategoriesList" VBox.vgrow="ALWAYS" styleClass="table-view" />
                        </VBox>
                    </HBox>
                </VBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>