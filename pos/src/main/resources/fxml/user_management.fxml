<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.pos.controller.UserManagementController"
      spacing="20" style="-fx-padding: 0;" stylesheets="@../css/style.css">
    
    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox>
            <Label text="Team Management" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />
            <Label text="Manage system users, roles and access permissions" style="-fx-text-fill: #64748b;" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="+ Add New Team Member" onAction="#handleAddUser" styleClass="btn-primary" prefHeight="40" />
        <Button text="↻ Refresh" onAction="#handleRefresh" styleClass="btn-ghost" prefHeight="40" />
    </HBox>
    
    <VBox styleClass="card" spacing="15">
        <HBox spacing="10">
            <TextField fx:id="searchField" promptText="Search by name, username or role..." 
                       onKeyReleased="#handleSearch" HBox.hgrow="ALWAYS" prefHeight="45" />
            <Button text="Search" onAction="#handleSearch" styleClass="btn-info" prefHeight="45" prefWidth="100" />
        </HBox>
    </VBox>
    
    <VBox styleClass="card" VBox.vgrow="ALWAYS" style="-fx-padding: 0;">
        <TableView fx:id="usersTable" VBox.vgrow="ALWAYS" styleClass="table-view">
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
            <columns>
                <TableColumn fx:id="colUsername" text="Username" prefWidth="120" />
                <TableColumn fx:id="colFullName" text="Full Name" prefWidth="250" />
                <TableColumn fx:id="colRole" text="Role" prefWidth="120" />
                <TableColumn fx:id="colActive" text="Status" prefWidth="100" />
                <TableColumn fx:id="colCreatedAt" text="Joined Date" prefWidth="150" />
            </columns>
        </TableView>
    </VBox>
    
    <HBox spacing="15" alignment="CENTER_LEFT">
        <Button text="Edit User" onAction="#handleEditUser" styleClass="btn-primary" prefHeight="40" />
        <Button text="Toggle Access" onAction="#handleToggleActive" styleClass="btn-ghost" prefHeight="40" />
        <Button text="Reset Password" onAction="#handleResetPassword" styleClass="btn-ghost" prefHeight="40" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="Remove User" onAction="#handleDeleteUser" styleClass="btn-danger" prefHeight="40" />
    </HBox>
    
    <!-- User Analysis Cards -->
    <HBox spacing="20">
        <VBox styleClass="card" HBox.hgrow="ALWAYS" alignment="CENTER">
            <Label text="TOTAL USERS" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #94a3b8;" />
            <Label fx:id="totalUsersLabel" text="0" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />
        </VBox>
        <VBox styleClass="card" HBox.hgrow="ALWAYS" alignment="CENTER">
            <Label text="ACTIVE ACCOUNTS" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #94a3b8;" />
            <Label fx:id="activeUsersLabel" text="0" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #10b981;" />
        </VBox>
        <VBox styleClass="card" HBox.hgrow="ALWAYS" alignment="CENTER">
            <Label text="ADMINISTRATORS" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #94a3b8;" />
            <Label fx:id="adminCountLabel" text="0" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #3b82f6;" />
        </VBox>
        <VBox styleClass="card" HBox.hgrow="ALWAYS" alignment="CENTER">
            <Label text="ATTENDANTS" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #94a3b8;" />
            <Label fx:id="attendantCountLabel" text="0" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #f59e0b;" />
        </VBox>
    </HBox>
</VBox>