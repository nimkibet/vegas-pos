<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.shape.Circle?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
           fx:controller="com.pos.controller.LoginController"
           stylesheets="@../css/style.css"
           style="-fx-background-color: #FFFFFF;"
           prefWidth="380">

    <VBox alignment="CENTER" spacing="0" prefWidth="380" maxWidth="380">
        <!-- Main Card (fits window exactly) -->
        <VBox styleClass="card" style="-fx-padding: 0; -fx-background-radius: 0; -fx-effect: none;" prefWidth="380" maxWidth="380">
            
            <!-- Branding Header -->
            <VBox styleClass="glass-header" alignment="CENTER" spacing="10" style="-fx-background-radius: 0; -fx-padding: 30 30;" maxWidth="Infinity">
                <StackPane style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 10;">
                    <Label text="V" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #064e3b;" />
                </StackPane>
                <VBox alignment="CENTER">
                    <Label text="VEGAS" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: white; -fx-letter-spacing: 4;" />
                    <Label text="SUPERMARKET" style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.7); -fx-letter-spacing: 2;" />
                </VBox>
                <Separator style="-fx-opacity: 0.15;" maxWidth="80" />
                <Label text="Fresh • Quality • Value" style="-fx-font-size: 10; -fx-text-fill: rgba(255,255,255,0.6); -fx-font-style: italic;" />
            </VBox>
            
            <!-- Login Form -->
            <VBox spacing="15" style="-fx-padding: 25 35;">
                <VBox alignment="CENTER" spacing="5">
                    <Label text="Secure Login" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />
                    <Label text="Enter your credentials to access the terminal" style="-fx-font-size: 11; -fx-text-fill: #64748b;" />
                </VBox>
                
                <!-- Fields -->
                <VBox spacing="12">
                    <VBox spacing="6">
                        <Label text="USERNAME" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #94a3b8;" />
                        <TextField fx:id="usernameField" promptText="Your username" onKeyPressed="#handleKeyPress" />
                    </VBox>
                    
                    <VBox spacing="6">
                        <Label text="PASSWORD" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #94a3b8;" />
                        <PasswordField fx:id="passwordField" promptText="Your password" onKeyPressed="#handleKeyPress" />
                    </VBox>
                </VBox>
                
                <Label fx:id="errorLabel" style="-fx-text-fill: -fx-danger; -fx-font-size: 11;" alignment="CENTER" maxWidth="Infinity" />
                
                <Button fx:id="loginButton" text="SIGN IN TO TERMINAL" defaultButton="true" onAction="#handleLogin" 
                        styleClass="btn-primary" prefHeight="45" maxWidth="Infinity" />
                
                <HBox alignment="CENTER" spacing="5">
                    <Label text="Running on" style="-fx-font-size: 10; -fx-text-fill: #94a3b8;" />
                    <Label text="Vegas POS v2.0 Pro" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: -fx-primary;" />
                </HBox>
            </VBox>
            
            <!-- System Status Footer -->
            <HBox style="-fx-background-color: #f8fafc; -fx-padding: 12; -fx-background-radius: 0;" alignment="CENTER">
                <HBox spacing="8" alignment="CENTER">
                    <Circle radius="3" fill="#10b981" />
                    <Label text="System Ready &amp; Secure" style="-fx-font-size: 10; -fx-text-fill: #64748b;" />
                </HBox>
            </HBox>
        </VBox>
    </VBox>
</StackPane>