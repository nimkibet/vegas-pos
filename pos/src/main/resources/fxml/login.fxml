<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pos.controller.LoginController" 
      alignment="CENTER" spacing="30" style="-fx-background-color: #e8f5e9;" 
      prefWidth="450" prefHeight="600">
    <padding>
        <Insets top="0" right="0" bottom="20" left="0"/>
    </padding>
    
    <!-- Login Card Container with Shadow -->
    <VBox style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 20, 0, 0, 10);" 
          alignment="CENTER" spacing="0" maxWidth="Infinity" minWidth="350">
        
        <!-- Logo Header Section -->
        <VBox style="-fx-background-color: #1a5f2a; -fx-padding: 40; -fx-background-radius: 16 16 0 0;" 
              alignment="CENTER" spacing="12">
            
            <Label text="VEGAS SUPERMARKET" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: white; -fx-letter-spacing: 2;">
                <font>
                    <Font name="Arial Bold" size="28" />
                </font>
            </Label>
            
            <Label text="________________________" style="-fx-text-fill: white; -fx-opacity: 0.8;" />
            
            <Label text="Fresh • Quality • Value" style="-fx-font-size: 11; -fx-text-fill: white; -fx-letter-spacing: 2; -fx-opacity: 0.7;" />
        </VBox>
        
        <!-- Login Form Section -->
        <VBox style="-fx-background-color: white; -fx-padding: 40; -fx-spacing: 20;" alignment="CENTER">
            
            <Label text="POS Login" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #1a5f2a;" />
            
            <!-- Username Field -->
            <VBox spacing="8">
                <Label text="Username" style="-fx-font-size: 13; -fx-font-weight: 600; -fx-text-fill: #4a5568;" />
                <TextField fx:id="usernameField" maxWidth="300" style="-fx-font-size: 15; -fx-padding: 12; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;"
                           onKeyPressed="#handleKeyPress" />
            </VBox>
            
            <!-- Password Field -->
            <VBox spacing="8">
                <Label text="Password" style="-fx-font-size: 13; -fx-font-weight: 600; -fx-text-fill: #4a5568;" />
                <PasswordField fx:id="passwordField" maxWidth="300" style="-fx-font-size: 15; -fx-padding: 12; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;"
                               onKeyPressed="#handleKeyPress" />
            </VBox>
            
            <!-- Error Message -->
            <Label fx:id="errorLabel" text="" style="-fx-font-size: 13; -fx-text-fill: #e53e3e; -fx-min-height: 20;" />
            
            <!-- Login Button -->
            <Button fx:id="loginButton" text="Sign In" defaultButton="true" onAction="#handleLogin" 
                    prefWidth="200" prefHeight="40" style="-fx-font-size: 15; -fx-font-weight: bold; -fx-background-radius: 8; -fx-background-color: #1a5f2a; -fx-text-fill: white; -fx-cursor: hand;" />
            
            <!-- Hint -->
            <Label text="Default: admin / admin123" style="-fx-font-size: 12; -fx-text-fill: #a0aec0;" />
        </VBox>
        
        <!-- Footer -->
        <StackPane style="-fx-background-color: #f7fafc; -fx-padding: 20; -fx-background-radius: 0 0 16 16;">
            <Label text="Vegas Supermarket POS v1.0 • Offline-First Point of Sale" 
                   style="-fx-font-size: 11; -fx-text-fill: #a0aec0; -fx-opacity: 0.8;" />
        </StackPane>
    </VBox>
</VBox>
