<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.shape.Circle?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
           fx:controller="com.pos.controller.CheckoutController"
           stylesheets="@../css/style.css" styleClass="root">
    
    <!-- Modal Card -->
    <VBox alignment="CENTER" spacing="0" maxWidth="500" maxHeight="700">
        <VBox styleClass="card" style="-fx-padding: 0; -fx-background-radius: 20;">
            
            <!-- Header -->
            <VBox styleClass="glass-header" alignment="CENTER" spacing="8" style="-fx-background-radius: 20 20 0 0; -fx-padding: 30 40;">
                <Label text="FINAL CHECKOUT" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: white; -fx-letter-spacing: 2;" />
                <Label text="Confirm payment and complete sale" style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.7);" />
            </VBox>
            
            <!-- Content Body -->
            <VBox spacing="25" style="-fx-padding: 40 50;">
                
                <!-- Amount Summary -->
                <VBox alignment="CENTER" spacing="10" style="-fx-background-color: #f8fafc; -fx-padding: 25; -fx-background-radius: 12;">
                    <Label text="GRAND TOTAL DUE" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #94a3b8;" />
                    <Label fx:id="totalDueLabel" text="KSh 0.00" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #064e3b;" />
                </VBox>
                
                <!-- Method Selection -->
                <VBox spacing="10">
                    <Label text="SELECT PAYMENT METHOD" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #94a3b8;" />
                    <HBox spacing="10" alignment="CENTER">
                        <fx:define>
                            <ToggleGroup fx:id="paymentGroup" />
                        </fx:define>
                        <ToggleButton fx:id="cashRadio" text="CASH" selected="true" toggleGroup="$paymentGroup" onAction="#handlePaymentMethodChanged" styleClass="toggle-button" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                        <ToggleButton fx:id="mpesaRadio" text="M-PESA" toggleGroup="$paymentGroup" onAction="#handlePaymentMethodChanged" styleClass="toggle-button" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                        <ToggleButton fx:id="splitRadio" text="SPLIT" toggleGroup="$paymentGroup" onAction="#handlePaymentMethodChanged" styleClass="toggle-button" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                        <ToggleButton fx:id="creditRadio" text="CREDIT" toggleGroup="$paymentGroup" onAction="#handlePaymentMethodChanged" styleClass="toggle-button" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                    </HBox>
                </VBox>
                
                <!-- Dynamic Input Sections -->
                <VBox spacing="20">
                    <!-- Customer (Credit Mode) -->
                    <VBox fx:id="customerSection" spacing="10" managed="false" visible="false">
                        <Label text="CUSTOMER NAME" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #94a3b8;" />
                        <HBox spacing="10">
                            <ComboBox fx:id="customerDropdown" HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="45" />
                            <Button text="+" onAction="#handleQuickAddCustomer" styleClass="btn-info" prefWidth="45" prefHeight="45" />
                        </HBox>
                    </VBox>

                    <!-- Tendered Amount -->
                    <VBox spacing="8">
                        <Label text="AMOUNT TENDERED" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #94a3b8;" />
                        <VBox fx:id="singlePaymentContainer">
                            <TextField fx:id="amountTenderedField" promptText="Enter amount paid" 
                                      style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #10b981;" 
                                      alignment="CENTER" prefHeight="55" onAction="#handleConfirmSale" onKeyReleased="#handleCalculateChange" />
                        </VBox>
                        <VBox fx:id="splitPaymentContainer" visible="false" managed="false" spacing="10">
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="Cash Amount: " styleClass="adaptive-text"/>
                                <TextField fx:id="splitCashInput" promptText="0.00" onKeyReleased="#handleCalculateChange" />
                            </HBox>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="M-PESA Amount: " styleClass="adaptive-text"/>
                                <TextField fx:id="splitMpesaInput" promptText="0.00" onKeyReleased="#handleCalculateChange" />
                            </HBox>
                        </VBox>
                    </VBox>
                </VBox>
                
                <!-- Change Display -->
                <VBox alignment="CENTER" spacing="5">
                    <Label text="CHANGE TO RETURN" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #94a3b8;" />
                    <Label fx:id="changeLabel" text="KSh 0.00" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #10b981;" />
                </VBox>
                
                <Label fx:id="errorLabel" style="-fx-text-fill: -fx-danger; -fx-font-size: 12;" alignment="CENTER" maxWidth="Infinity" />
                
                <!-- Footer Buttons -->
                <HBox spacing="15">
                    <Button text="Cancel" onAction="#handleCancel" styleClass="btn-ghost" prefHeight="50" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                    <Button fx:id="confirmButton" text="COMPLETE SALE" onAction="#handleConfirmSale" 
                            styleClass="btn-primary" prefHeight="50" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                </HBox>
            </VBox>
            
            <HBox style="-fx-background-color: #f8fafc; -fx-padding: 15; -fx-background-radius: 0 0 20 20;" alignment="CENTER">
                <Label text="Enter to Confirm • Esc to Cancel" style="-fx-font-size: 10; -fx-text-fill: #94a3b8;" />
            </HBox>
        </VBox>
    </VBox>
</StackPane>