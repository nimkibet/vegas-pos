<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.pos.controller.AdminDebtorsController"
      stylesheets="@../css/style.css" spacing="20" style="-fx-padding: 0;">

    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox>
            <Label text="Accounts Receivable" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />
            <Label text="Monitor outstanding customer debts and credit limits" style="-fx-text-fill: #64748b;" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#handleRefresh" styleClass="btn-ghost" text="↻ Refresh Data" prefHeight="40" />
    </HBox>
    
    <VBox styleClass="card" VBox.vgrow="ALWAYS" style="-fx-padding: 0;">
        <TableView fx:id="debtorsTable" VBox.vgrow="ALWAYS" styleClass="table-view">
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
            <columns>
                <TableColumn fx:id="colCustomerName" text="Customer Name" prefWidth="200" />
                <TableColumn fx:id="colPhone" text="Phone Number" prefWidth="130" />
                <TableColumn fx:id="colPendingBatches" text="Unpaid Batches" prefWidth="110" />
                <TableColumn fx:id="colTotalDebt" text="Outstanding (KSh)" prefWidth="150" style="-fx-font-weight: bold;" />
                <TableColumn fx:id="colCreditLimit" text="Credit Limit (KSh)" prefWidth="150" />
                <TableColumn fx:id="colLimitStatus" text="Status" prefWidth="100" />
            </columns>
        </TableView>
    </VBox>
    
    <HBox spacing="15" alignment="CENTER_LEFT">
        <Button text="View Customer Ledger" styleClass="btn-primary" prefHeight="40" onAction="#handleViewLedger" />
        <Button text="Record Payment" styleClass="btn-success" prefHeight="40" onAction="#handleRecordPayment" />
        <Button text="✏ Edit Credit Limit" styleClass="btn-warning" prefHeight="40" onAction="#handleEditCreditLimit"
                style="-fx-background-color: #f59e0b; -fx-text-fill: white;" />
        <Region HBox.hgrow="ALWAYS" />
        <Label text="Total Debt Portfolio:" style="-fx-text-fill: #64748b;" />
        <Label fx:id="totalPortfolioLabel" text="KSh 0.00" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />
    </HBox>

</VBox>