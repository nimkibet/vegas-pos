<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pos.controller.StockInFormController"
      stylesheets="@../css/style.css"
      spacing="20" style="-fx-padding: 0;">

    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox>
            <Label text="Inventory Restock" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />
            <Label text="Record new shipments and manage supplier transactions" style="-fx-text-fill: #64748b;" />
        </VBox>
    </HBox>

    <!-- Entry Form Section -->
    <VBox styleClass="card" spacing="20">
        <HBox spacing="30">
            <!-- Supplier Section -->
            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <Label text="SUPPLIER INFORMATION" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #94a3b8;" />
                <HBox spacing="10">
                    <ComboBox fx:id="supplierComboBox" editable="true" promptText="Select or type supplier..." HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="40" />
                    <Button text="Save" onAction="#handleSaveSupplier" styleClass="btn-ghost" prefHeight="40" />
                </HBox>
            </VBox>

            <!-- Product Entry Section -->
            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <Label text="ITEM SEARCH" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #94a3b8;" />
                <HBox spacing="10">
                    <TextField fx:id="productSearchField" onAction="#handleProductSearch" promptText="Name or barcode..." HBox.hgrow="ALWAYS" prefHeight="40" />
                    <Button text="Find" onAction="#handleProductSearch" styleClass="btn-info" prefHeight="40" />
                    <Button text="Register New" onAction="#handleRegisterNewProduct" styleClass="btn-ghost" prefHeight="40" />
                </HBox>
            </VBox>
        </HBox>

        <Separator style="-fx-opacity: 0.1;" />

        <FlowPane hgap="30" vgap="15" alignment="BOTTOM_LEFT">
            <VBox spacing="10">
                <Label text="RECOGNIZED UNIT" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #94a3b8;" />
                <Label fx:id="tierFeedbackLabel" text="Scan a barcode to begin..." styleClass="adaptive-text" style="-fx-font-weight: bold; -fx-text-fill: #0F766E; -fx-font-size: 14px;" prefHeight="40" prefWidth="240"/>
            </VBox>
            <VBox spacing="10">
                <Label text="UNIT COST (KSh)" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #94a3b8;" />
                <TextField fx:id="buyingPriceField" promptText="0.00" prefWidth="160" prefHeight="40" />
            </VBox>
            <VBox spacing="10">
                <Label text="QUANTITY" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #94a3b8;" />
                <TextField fx:id="quantityField" promptText="Qty" prefWidth="140" prefHeight="40" />
            </VBox>
            <VBox spacing="10" alignment="BOTTOM_LEFT">
                <Label text="" style="-fx-font-size: 10;" />
                <Button text="+ Add to Shipment" onAction="#handleAddLine" styleClass="btn-primary" prefHeight="40" />
            </VBox>
        </FlowPane>
    </VBox>

    <!-- Draft Shipment Table -->
    <VBox spacing="10" VBox.vgrow="ALWAYS">
        <Label text="SHIPMENT PREVIEW" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #94a3b8;" />
        <VBox styleClass="card" VBox.vgrow="ALWAYS" style="-fx-padding: 0;">
            <TableView fx:id="draftTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                <columns>
                    <TableColumn text="Product Name" fx:id="colDraftProduct" prefWidth="250" />
                    <TableColumn text="Barcode" fx:id="colDraftBarcode" prefWidth="120" />
                    <TableColumn text="Packaging Tier" fx:id="colDraftTier" prefWidth="120" />
                    <TableColumn text="Quantity Received" fx:id="colDraftQty" prefWidth="100" />
                    <TableColumn text="Unit Wholesale Cost" fx:id="colDraftBuying" prefWidth="120" />
                    <TableColumn text="Total Line Cost" fx:id="colDraftLineTotal" prefWidth="150" style="-fx-font-weight: bold;" />
                </columns>
            </TableView>
        </VBox>
        <HBox spacing="15" alignment="CENTER_LEFT">
            <VBox spacing="4">
                <Label text="PAYMENT SOURCE" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #94a3b8;" />
                <ComboBox fx:id="paymentSourceDropdown" prefWidth="220" prefHeight="38"
                          promptText="Select payment source..." />
            </VBox>
            <!-- Debt offset panel — shown only when "Debt (Offset Account)" is selected -->
            <VBox fx:id="debtorBox" spacing="8" visible="false" managed="false">
                <HBox spacing="12" alignment="BOTTOM_LEFT">
                    <VBox spacing="4">
                        <Label text="OFFSET DEBTOR" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #94a3b8;" />
                        <ComboBox fx:id="debtorDropdown" prefWidth="200" prefHeight="38"
                                  promptText="Select debtor..." />
                    </VBox>
                    <VBox spacing="4">
                        <Label text="DEBT OFFSET AMOUNT (KSh)" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #94a3b8;" />
                        <TextField fx:id="debtorOffsetAmount" prefWidth="160" prefHeight="38"
                                   promptText="0.00 (full amount = all debt)" />
                    </VBox>
                    <VBox spacing="4">
                        <Label text="REMAINING CASH DUE" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #94a3b8;" />
                        <Label fx:id="remainingCashLabel" text="KSh 0.00"
                               style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #0f172a; -fx-padding: 6 0 0 0;" />
                    </VBox>
                </HBox>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Remove Line" onAction="#handleRemoveDraftLine" styleClass="btn-danger" />
            <Button text="Confirm Shipment" onAction="#handleRecordStockIn" styleClass="btn-success" prefHeight="40" prefWidth="180" />
        </HBox>
    </VBox>

    <!-- History / Transactions -->
    <VBox spacing="10" prefHeight="250">
        <HBox alignment="CENTER_LEFT">
            <Label text="RECENT TRANSACTIONS" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #94a3b8;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Mark as Paid" onAction="#handleClearPayment" styleClass="btn-ghost" style="-fx-font-size: 11; -fx-padding: 5 10;" />
        </HBox>
        <VBox styleClass="card" VBox.vgrow="ALWAYS" style="-fx-padding: 0;">
            <TableView fx:id="transactionsTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                <columns>
                    <TableColumn text="Date" fx:id="colTxDate" />
                    <TableColumn text="Supplier" fx:id="colTxSupplier" prefWidth="200" />
                    <TableColumn text="Total Value" fx:id="colTxTotal" />
                    <TableColumn text="Payment Status" fx:id="colTxStatus" />
                </columns>
            </TableView>
        </VBox>
    </VBox>
</VBox>