<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.pos.controller.UserFormController"
      spacing="15" style="-fx-padding: 20;">

    <Label text="User Details" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="120" prefWidth="120"/>
            <ColumnConstraints minWidth="200" prefWidth="200"/>
        </columnConstraints>

        <Label text="Username:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="usernameField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Password:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <PasswordField fx:id="passwordField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Confirm:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <PasswordField fx:id="confirmPasswordField" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Label text="Full Name:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <TextField fx:id="fullNameField" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

        <Label text="Role:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <ComboBox fx:id="roleComboBox" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

        <Label text="Active:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
        <CheckBox fx:id="activeCheckBox" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
    </GridPane>

    <Label fx:id="errorLabel" style="-fx-font-size: 12px;"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="saveButton" text="Save" onAction="#handleSave" 
                style="-fx-background-color: #2196F3; -fx-text-fill: white;" 
                prefWidth="80"/>
        <Button text="Cancel" onAction="#handleCancel" prefWidth="80"/>
    </HBox>
</VBox>
