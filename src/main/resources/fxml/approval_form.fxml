<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.pos.controller.ApprovalFormController"
      style="-fx-padding: 20; -fx-spacing: 15; -fx-background-color: #f8f9fa;">
    
    <Label text="Approve Product" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #1a5f2a;" />
    <Label text="Review and adjust prices before approval" style="-fx-font-size: 12; -fx-text-fill: #4a5568;" />
    
    <GridPane hgap="15" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="120" />
            <ColumnConstraints hgrow="ALWAYS" prefWidth="200" />
        </columnConstraints>
        
        <Label text="Barcode:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-size: 13; -fx-text-fill: #4a5568;" />
        <TextField fx:id="barcodeField" GridPane.columnIndex="1" GridPane.rowIndex="0" 
                   style="-fx-font-size: 13; -fx-padding: 10;" />
        
        <Label text="Product Name:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-size: 13; -fx-text-fill: #4a5568;" />
        <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="1" 
                   style="-fx-font-size: 13; -fx-padding: 10;" />
        
        <Label text="Category:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-size: 13; -fx-text-fill: #4a5568;" />
        <TextField fx:id="categoryField" GridPane.columnIndex="1" GridPane.rowIndex="2" 
                   style="-fx-font-size: 13; -fx-padding: 10;" />
        
        <Label text="Retail Price:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-size: 13; -fx-text-fill: #4a5568;" />
        <TextField fx:id="retailPriceField" GridPane.columnIndex="1" GridPane.rowIndex="3" 
                   style="-fx-font-size: 13; -fx-padding: 10;" />
        
        <Label text="Wholesale Price:" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-font-size: 13; -fx-text-fill: #4a5568;" />
        <TextField fx:id="wholesalePriceField" GridPane.columnIndex="1" GridPane.rowIndex="4" 
                   style="-fx-font-size: 13; -fx-padding: 10;" />
        
        <Label text="Stock Quantity:" GridPane.columnIndex="0" GridPane.rowIndex="5" style="-fx-font-size: 13; -fx-text-fill: #4a5568;" />
        <TextField fx:id="stockField" GridPane.columnIndex="1" GridPane.rowIndex="5" 
                   style="-fx-font-size: 13; -fx-padding: 10;" />
    </GridPane>
    
    <Label fx:id="errorLabel" style="-fx-font-size: 12; -fx-text-fill: #e53e3e;" />
    
    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
        <Button text="Reject" onAction="#handleReject" styleClass="btn-danger" />
        <Button text="Cancel" onAction="#handleCancel" styleClass="button" />
        <Button text="Approve" onAction="#handleApprove" styleClass="btn-success" />
    </HBox>
</VBox>