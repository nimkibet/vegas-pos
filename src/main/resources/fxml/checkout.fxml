<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pos.controller.CheckoutController">
    
    <!-- Checkout Card -->
    <VBox style="-fx-background-color: white; -fx-background-radius: 16;" 
          alignment="CENTER" spacing="0" maxWidth="400">
        
        <!-- Header -->
        <VBox style="-fx-background-color: #1a5f2a; -fx-padding: 20 30; -fx-background-radius: 16 16 0 0;" 
              alignment="CENTER" spacing="5">
            <Label text="CHECKOUT" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white; -fx-letter-spacing: 2;">
                <font>
                    <Font name="Segoe UI Bold" size="22" />
                </font>
            </Label>
            <Label text="Complete your transaction" style="-fx-font-size: 12; -fx-text-fill: white; -fx-opacity: 0.8;" />
        </VBox>
        
        <!-- Body -->
        <VBox style="-fx-padding: 30; -fx-spacing: 20;" alignment="CENTER" spacing="18">
            
            <!-- Total Due Section -->
            <VBox spacing="5" alignment="CENTER">
                <Label text="Total Amount Due" style="-fx-font-size: 13; -fx-text-fill: #718096;" />
                <Label fx:id="totalDueLabel" text="KSh0.00" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #1a5f2a;" />
            </VBox>
            
            <!-- Customer Selection (for Credit) -->
            <VBox spacing="10" visible="false" fx:id="customerSection">
                <Label text="Customer" style="-fx-font-size: 13; -fx-font-weight: 600; -fx-text-fill: #4a5568;" />
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <ComboBox fx:id="customerDropdown" prefWidth="260" style="-fx-font-size: 14; -fx-padding: 8;" />
                    <Button text="+" onAction="#handleQuickAddCustomer" styleClass="btn-info"
                            style="-fx-font-size: 14; -fx-padding: 8 12; -fx-background-color: #17a2b8; -fx-text-fill: white; -fx-background-radius: 4;" />
                </HBox>
            </VBox>
            
            <!-- Payment Method -->
            <VBox spacing="10">
                <Label text="Payment Method" style="-fx-font-size: 13; -fx-font-weight: 600; -fx-text-fill: #4a5568;" />
                <HBox spacing="20">
                    <RadioButton fx:id="cashRadio" text="Cash" selected="true" onAction="#handlePaymentMethodChanged"
                                style="-fx-font-size: 14; -fx-padding: 8 16;">
                        <toggleGroup>
                            <ToggleGroup fx:id="paymentGroup" />
                        </toggleGroup>
                    </RadioButton>
                    <RadioButton fx:id="mpesaRadio" text="M-Pesa" onAction="#handlePaymentMethodChanged" toggleGroup="$paymentGroup"
                                style="-fx-font-size: 14; -fx-padding: 8 16;" />
                    <RadioButton fx:id="splitRadio" text="Split" onAction="#handlePaymentMethodChanged" toggleGroup="$paymentGroup"
                                style="-fx-font-size: 14; -fx-padding: 8 16;" />
                    <RadioButton fx:id="creditRadio" text="Credit" onAction="#handlePaymentMethodChanged" toggleGroup="$paymentGroup"
                                style="-fx-font-size: 14; -fx-padding: 8 16;" />
                </HBox>
            </VBox>
            
            <!-- Split Payment Fields -->
            <VBox fx:id="splitPaymentFields" spacing="10" visible="false">
                <Label text="Split Payment" style="-fx-font-size: 13; -fx-font-weight: 600; -fx-text-fill: #4a5568;" />
                <HBox spacing="15">
                    <VBox spacing="5">
                        <Label text="Cash (KSh)" style="-fx-font-size: 12; -fx-text-fill: #718096;" />
                        <TextField fx:id="cashAmountField" prefWidth="120" style="-fx-font-size: 16; -fx-padding: 8; -fx-alignment: center;"
                                  promptText="0.00" onAction="#handleCalculateChange" onKeyReleased="#handleCalculateChange" />
                    </VBox>
                    <VBox spacing="5">
                        <Label text="M-Pesa (KSh)" style="-fx-font-size: 12; -fx-text-fill: #718096;" />
                        <TextField fx:id="mpesaAmountField" prefWidth="120" style="-fx-font-size: 16; -fx-padding: 8; -fx-alignment: center;"
                                  promptText="0.00" onAction="#handleCalculateChange" onKeyReleased="#handleCalculateChange" />
                    </VBox>
                </HBox>
            </VBox>
            
            <!-- Amount Tendered -->
            <VBox spacing="8">
                <Label text="Amount Tendered (KSh)" style="-fx-font-size: 13; -fx-font-weight: 600; -fx-text-fill: #4a5568;" />
                <TextField fx:id="amountTenderedField" prefWidth="250" style="-fx-font-size: 18; -fx-padding: 12; -fx-alignment: center;"
                          promptText="Enter amount" onAction="#handleCalculateChange" onKeyReleased="#handleCalculateChange" />
            </VBox>
            
            <!-- Change Display -->
            <VBox spacing="5" alignment="CENTER">
                <Label text="Change" style="-fx-font-size: 13; -fx-text-fill: #718096;" />
                <Label fx:id="changeLabel" text="KSh0.00" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #28a745;" />
            </VBox>
            
            <!-- Error Message -->
            <Label fx:id="errorLabel" text="" style="-fx-font-size: 12; -fx-text-fill: #e53e3e; -fx-min-height: 18;" />
            
            <!-- Action Buttons -->
            <HBox spacing="20" alignment="CENTER">
                <Button fx:id="cancelButton" text="Cancel" onAction="#handleCancel" 
                       style="-fx-font-size: 14; -fx-padding: 12 30; -fx-background-color: #e2e8f0; -fx-text-fill: #4a5568; -fx-background-radius: 6;" />
                <Button fx:id="confirmButton" text="Confirm Sale" onAction="#handleConfirmSale" 
                       style="-fx-font-size: 14; -fx-font-weight: bold; -fx-padding: 12 30; -fx-background-color: #28a745; -fx-text-fill: white; -fx-background-radius: 6;" />
            </HBox>
        </VBox>
        
        <!-- Footer -->
        <StackPane style="-fx-background-color: #f7fafc; -fx-padding: 15; -fx-background-radius: 0 0 16 16;">
            <Label text="Press Enter to confirm • Escape to cancel" style="-fx-font-size: 11; -fx-text-fill: #a0aec0;" />
        </StackPane>
    </VBox>
</StackPane>
