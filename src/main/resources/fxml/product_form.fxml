<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pos.controller.ProductFormController"
            stylesheets="@../css/style.css">
    <padding>
        <Insets top="24" right="28" bottom="24" left="28"/>
    </padding>

    <top>
        <Label text="Product Management" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #1a5f2a;"/>
    </top>

    <center>
        <HBox spacing="40" alignment="TOP_LEFT" BorderPane.alignment="CENTER" maxWidth="Infinity">
            <VBox spacing="14" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-min-width: 280;">
                <Label text="Basic Details" style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                <VBox spacing="6">
                    <Label text="Barcode" style="-fx-font-size: 12; -fx-text-fill: #4a5568;"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="barcodeField" promptText="Scan or enter barcode" HBox.hgrow="ALWAYS"
                                   style="-fx-font-size: 13; -fx-padding: 10;"/>
                        <Button text="Generate" onAction="#handleGenerateBarcode" styleClass="button"/>
                    </HBox>
                </VBox>
                <VBox spacing="6">
                    <Label text="Name" style="-fx-font-size: 12; -fx-text-fill: #4a5568;"/>
                    <TextField fx:id="nameField" promptText="Product name"
                               style="-fx-font-size: 13; -fx-padding: 10;"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="Category" style="-fx-font-size: 12; -fx-text-fill: #4a5568;"/>
                    <HBox spacing="10">
                        <ComboBox fx:id="categoryCombo" editable="true" promptText="Select or type category"
                                  style="-fx-font-size: 13;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <ComboBox fx:id="unitTypeComboBox" promptText="Unit" prefWidth="100"
                                  style="-fx-font-size: 13;"/>
                    </HBox>
                </VBox>
            </VBox>

            <VBox spacing="14" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-min-width: 280;">
                <Label text="Pricing &amp; Stock" style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                <VBox spacing="6">
                    <Label text="Retail Price" style="-fx-font-size: 12; -fx-text-fill: #4a5568;"/>
                    <TextField fx:id="retailPriceField" promptText="0.00"
                               style="-fx-font-size: 13; -fx-padding: 10;"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="Wholesale Price" style="-fx-font-size: 12; -fx-text-fill: #4a5568;"/>
                    <TextField fx:id="wholesalePriceField" promptText="0.00"
                               style="-fx-font-size: 13; -fx-padding: 10;"/>
                </VBox>

                <Separator style="-fx-padding: 8 0;"/>

                <Label text="Bulk / Box" style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                <CheckBox fx:id="hasBulkCheckbox" text="Has Bulk/Box Option?" style="-fx-font-size: 13;"/>

                <VBox fx:id="bulkFieldsContainer" spacing="12" visible="false" managed="false">
                    <VBox spacing="6">
                        <Label text="Box Barcode" style="-fx-font-size: 12; -fx-text-fill: #4a5568;"/>
                        <TextField fx:id="bulkBarcodeField" promptText="Case / outer barcode"
                                   style="-fx-font-size: 13; -fx-padding: 10;"/>
                    </VBox>
                    <VBox spacing="6">
                        <Label text="Box Price" style="-fx-font-size: 12; -fx-text-fill: #4a5568;"/>
                        <TextField fx:id="bulkPriceField" promptText="0.00"
                                   style="-fx-font-size: 13; -fx-padding: 10;"/>
                    </VBox>
                    <VBox spacing="6">
                        <Label text="Base Units per Bulk (e.g., 50 for a 50kg bag, 12 for a dozen)" style="-fx-font-size: 12; -fx-text-fill: #4a5568;"/>
                        <TextField fx:id="piecesPerBoxField" promptText="e.g. 12"
                                   style="-fx-font-size: 13; -fx-padding: 10;"/>
                    </VBox>
                    <VBox spacing="6">
                        <Label text="Bulk Items Received" style="-fx-font-size: 12; -fx-text-fill: #4a5568;"/>
                        <TextField fx:id="boxesReceivedField" promptText="0"
                                   style="-fx-font-size: 13; -fx-padding: 10;"/>
                    </VBox>
                    <Label text="Units per bulk, bulk barcode, and shelf price for one bulk item." 
                           style="-fx-font-size: 11; -fx-text-fill: #718096; -fx-font-style: italic;"/>
                </VBox>

                <HBox fx:id="looseStockContainer" spacing="12" alignment="CENTER_LEFT">
                    <Label text="Loose Units Received" style="-fx-font-size: 12; -fx-text-fill: #4a5568;"/>
                    <TextField fx:id="loosePiecesField" promptText="0" prefWidth="120"
                               style="-fx-font-size: 13; -fx-padding: 10;"/>
                </HBox>

                <Separator style="-fx-padding: 8 0;"/>
                <VBox spacing="8">
                    <Label text="Variant Generation" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                    <HBox spacing="15">
                        <CheckBox fx:id="generateHalfCheck" text="Auto-Generate Half (0.5)" style="-fx-font-size: 12;"/>
                        <CheckBox fx:id="generateQuarterCheck" text="Auto-Generate Quarter (0.25)" style="-fx-font-size: 12;"/>
                    </HBox>
                </VBox>
            </VBox>
        </HBox>
    </center>

    <bottom>
        <VBox spacing="12" BorderPane.alignment="CENTER">
            <Label fx:id="errorLabel" style="-fx-font-size: 12; -fx-text-fill: #e53e3e;"/>
            <HBox alignment="CENTER_RIGHT" spacing="12">
                <Button text="Clear" onAction="#handleClear" styleClass="button"/>
                <Button text="Save Product" onAction="#handleSave" styleClass="btn-primary"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>
