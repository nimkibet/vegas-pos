<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="800.0" spacing="20.0" styleClass="main-container" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pos.controller.CustomerLedgerController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <Label text="Customer Ledger - Debt Collection">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>
        
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <Label text="Select Debtor:" />
                <ComboBox fx:id="customerDropdown" prefWidth="300.0" promptText="Choose a customer..." />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="totalDebtLabel" text="Total Debt: KSh 0.00" style="-fx-font-weight: bold; -fx-text-fill: #c53030; -fx-font-size: 16px;" />
            </children>
        </HBox>
        
        <TableView fx:id="unpaidSalesTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="saleIdColumn" prefWidth="150.0" text="Sale ID" />
                <TableColumn fx:id="dateColumn" prefWidth="150.0" text="Date" />
                <TableColumn fx:id="totalAmountColumn" prefWidth="120.0" text="Total Amount" />
                <TableColumn fx:id="balanceDueColumn" prefWidth="120.0" text="Balance Due" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
        
        <HBox alignment="CENTER_RIGHT" spacing="15.0">
            <children>
                <Label text="Payment Amount:" />
                <TextField fx:id="paymentAmountField" prefWidth="150.0" promptText="0.00" />
                <Button mnemonicParsing="false" onAction="#handleApplyPayment" prefHeight="40.0" prefWidth="150.0" styleClass="btn-success" text="💰 Apply Payment" />
            </children>
        </HBox>
    </children>
</VBox>
