<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pos.controller.AdminController"
            stylesheets="@../css/style.css">
    
    <!-- Top Header -->
    <top>
        <HBox style="-fx-background-color: #1a5f2a; -fx-padding: 15 20;" alignment="CENTER_LEFT" maxWidth="Infinity">
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label text="⚙️" style="-fx-font-size: 24; -fx-text-fill: white;" />
                <Label text="Admin Dashboard" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: white;" />
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <HBox spacing="12" alignment="CENTER_RIGHT">
                <Button text="Cashier (POS)" onAction="#handleOpenCashierTerminal" styleClass="action-btn" />
                <Button text="Operations backoffice" onAction="#handleOpenOperationsBackoffice"
                        style="-fx-font-size: 12; -fx-padding: 8 16; -fx-background-color: #2f855a; -fx-text-fill: white; -fx-background-radius: 5;" />
                <Button text="Logout" onAction="#handleLogout" styleClass="btn-danger" />
            </HBox>
        </HBox>
    </top>
    
    <!-- Main Content -->
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE" style="-fx-background-color: #f8f9fa;">
            
            <!-- Dashboard Tab -->
            <Tab text="Dashboard">
                <ScrollPane fitToWidth="true" style="-fx-background-color: #f8f9fa;">
                    <VBox spacing="20" style="-fx-padding: 20;">
                        
                        <!-- Stats Cards Row -->
                        <HBox spacing="15">
                            <!-- Today's Revenue Card -->
                            <VBox styleClass="panel" HBox.hgrow="ALWAYS" alignment="CENTER">
                                <Label text="Today's Revenue" style="-fx-font-size: 14; -fx-text-fill: #6c757d;" />
                                <Label fx:id="todayRevenueLabel" text="KSh0.00" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1a5f2a;" />
                            </VBox>
                            
                            <!-- Today's Transactions Card -->
                            <VBox styleClass="panel" HBox.hgrow="ALWAYS" alignment="CENTER">
                                <Label text="Transactions Today" style="-fx-font-size: 14; -fx-text-fill: #6c757d;" />
                                <Label fx:id="todayTransactionsLabel" text="0" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1a5f2a;" />
                            </VBox>
                            
                            <!-- Total Products Card -->
                            <VBox styleClass="panel" HBox.hgrow="ALWAYS" alignment="CENTER">
                                <Label text="Total Products" style="-fx-font-size: 14; -fx-text-fill: #6c757d;" />
                                <Label fx:id="totalProductsLabel" text="0" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1a5f2a;" />
                            </VBox>
                            
                            <!-- Total Users Card -->
                            <VBox styleClass="panel" HBox.hgrow="ALWAYS" alignment="CENTER">
                                <Label text="Total Users" style="-fx-font-size: 14; -fx-text-fill: #6c757d;" />
                                <Label fx:id="totalUsersLabel" text="0" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1a5f2a;" />
                            </VBox>
                        </HBox>
                        
                        <!-- Charts Row -->
                        <HBox spacing="15">
                            <!-- 7-Day Revenue Line Chart -->
                            <VBox styleClass="panel" HBox.hgrow="ALWAYS">
                                <Label text="7-Day Revenue Trend" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1a5f2a;" />
                                <LineChart fx:id="revenueChart" VBox.vgrow="ALWAYS" prefHeight="250" style="-fx-background-color: transparent;">
                                    <xAxis>
                                        <CategoryAxis label="Date" style="-fx-font-size: 11;" />
                                    </xAxis>
                                    <yAxis>
                                        <NumberAxis label="Revenue (KSh)" style="-fx-font-size: 11;" />
                                    </yAxis>
                                </LineChart>
                            </VBox>
                            
                            <!-- Top Selling Items Pie Chart -->
                            <VBox styleClass="panel" HBox.hgrow="ALWAYS">
                                <Label text="Top 5 Selling Items" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1a5f2a;" />
                                <PieChart fx:id="topItemsChart" VBox.vgrow="ALWAYS" prefHeight="250" style="-fx-background-color: transparent;" />
                            </VBox>
                        </HBox>
                        
                        <!-- Recent Sales Table -->
                        <VBox styleClass="panel">
                            <Label text="Recent Sales" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1a5f2a;" />
                            <TableView fx:id="recentSalesTable" VBox.vgrow="ALWAYS" styleClass="table-view" prefHeight="200">
                                <columns>
                                    <TableColumn text="Sale ID" fx:id="colSaleId" prefWidth="200" />
                                    <TableColumn text="Date" fx:id="colSaleDate" prefWidth="150" />
                                    <TableColumn text="Items" fx:id="colItemCount" prefWidth="80" />
                                    <TableColumn text="Total" fx:id="colSaleTotal" prefWidth="100" />
                                    <TableColumn text="Status" fx:id="colSyncStatus" prefWidth="100" />
                                </columns>
                            </TableView>
                        </VBox>
                        
                    </VBox>
                </ScrollPane>
            </Tab>
            
            <!-- Transaction History Tab -->
            <Tab text="Transaction History">
                <VBox spacing="15" style="-fx-padding: 20;">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Search:" style="-fx-font-size: 14; -fx-text-fill: #4a5568;" />
                        <TextField fx:id="historySearchField" promptText="Search by Sale ID or Date..." 
                                   onAction="#handleHistorySearch" HBox.hgrow="ALWAYS" 
                                   style="-fx-font-size: 13; -fx-padding: 8;" />
                        <DatePicker fx:id="historyDatePicker" style="-fx-font-size: 13;" />
                        <Button text="Search" onAction="#handleHistorySearch" styleClass="btn-primary" />
                    </HBox>
                    
                    <TableView fx:id="historyTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                        <columns>
                            <TableColumn text="Sale ID" fx:id="colHistoryId" prefWidth="180" />
                            <TableColumn text="Date" fx:id="colHistoryDate" prefWidth="140" />
                            <TableColumn text="Cashier" fx:id="colHistoryCashier" prefWidth="120" />
                            <TableColumn text="Items" fx:id="colHistoryItems" prefWidth="60" />
                            <TableColumn text="Total" fx:id="colHistoryTotal" prefWidth="100" />
                            <TableColumn text="Payment" fx:id="colHistoryPayment" prefWidth="100" />
                            <TableColumn text="Status" fx:id="colHistoryStatus" prefWidth="100" />
                        </columns>
                    </TableView>
                    
                    <HBox spacing="10">
                        <Button text="View Details" onAction="#handleViewSaleDetails" styleClass="btn-info" />
                        <Button text="Process Refund" onAction="#handleProcessRefund" styleClass="btn-warning" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button text="Export to CSV" onAction="#handleExportHistory" styleClass="button" />
                    </HBox>
                </VBox>
            </Tab>
            
            <!-- Low Stock Tab -->
            <Tab text="Low Stock">
                <VBox spacing="15" style="-fx-padding: 20;">
                    <HBox spacing="10">
                        <Button text="Refresh" onAction="#handleRefreshLowStock" styleClass="button" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button text="Generate Reorder List" onAction="#handleGenerateReorderList" styleClass="btn-primary" />
                    </HBox>
                    
                    <TableView fx:id="lowStockTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                        <columns>
                            <TableColumn text="Barcode" fx:id="colLowStockBarcode" prefWidth="120" />
                            <TableColumn text="Product Name" fx:id="colLowStockName" prefWidth="200" />
                            <TableColumn text="Current Stock" fx:id="colLowStockQty" prefWidth="100" />
                            <TableColumn text="Min Level" fx:id="colLowStockMin" prefWidth="100" />
                            <TableColumn text="Retail Price" fx:id="colLowStockRetail" prefWidth="100" />
                            <TableColumn text="Category" fx:id="colLowStockCategory" prefWidth="120" />
                        </columns>
                    </TableView>
                </VBox>
            </Tab>
            
            <!-- Pending Approvals Tab -->
            <Tab text="Pending Approvals">
                <VBox spacing="15" style="-fx-padding: 20;">
                    <HBox spacing="10">
                        <Label text="Products awaiting admin approval" style="-fx-font-size: 14; -fx-text-fill: #4a5568;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button text="Refresh" onAction="#handleRefreshPendingApprovals" styleClass="button" />
                    </HBox>
                    
                    <TableView fx:id="pendingApprovalsTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                        <columns>
                            <TableColumn text="Barcode" fx:id="colPendingBarcode" prefWidth="120" />
                            <TableColumn text="Product Name" fx:id="colPendingName" prefWidth="180" />
                            <TableColumn text="Category" fx:id="colPendingCategory" prefWidth="100" />
                            <TableColumn text="Retail Price" fx:id="colPendingRetail" prefWidth="100" />
                            <TableColumn text="Wholesale Price" fx:id="colPendingWholesale" prefWidth="120" />
                            <TableColumn text="Stock" fx:id="colPendingStock" prefWidth="80" />
                            <TableColumn text="Added Date" fx:id="colPendingAddedBy" prefWidth="120" />
                        </columns>
                    </TableView>
                    
                    <HBox spacing="10">
                        <Button text="Approve Selected" onAction="#handleApproveProduct" styleClass="btn-primary" />
                        <Button text="Reject Selected" onAction="#handleRejectProduct" styleClass="btn-danger" />
                    </HBox>
                </VBox>
            </Tab>
            
            <!-- Product Management: same inventory UI as the POS backoffice -->
            <Tab text="Product Management">
                <fx:include fx:id="inventoryManagement" source="inventory_management.fxml" maxWidth="Infinity" maxHeight="Infinity" />
            </Tab>
            
            <!-- User Management Tab -->
            <Tab text="User Management">
                <VBox spacing="15" style="-fx-padding: 20;">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Search:" style="-fx-font-size: 14; -fx-text-fill: #4a5568;" />
                        <TextField fx:id="userSearchField" promptText="Search users..." 
                                   onAction="#handleUserSearch" HBox.hgrow="ALWAYS" 
                                   style="-fx-font-size: 13; -fx-padding: 8;" />
                        <Button text="Search" onAction="#handleUserSearch" styleClass="btn-primary" />
                    </HBox>
                    
                    <TableView fx:id="usersTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                        <columns>
                            <TableColumn text="Username" fx:id="colUserUsername" prefWidth="150" />
                            <TableColumn text="Full Name" fx:id="colUserFullName" prefWidth="180" />
                            <TableColumn text="Role" fx:id="colUserRole" prefWidth="100" />
                            <TableColumn text="Active" fx:id="colUserActive" prefWidth="80" />
                            <TableColumn text="Created" fx:id="colUserCreatedAt" prefWidth="120" />
                        </columns>
                    </TableView>
                    
                    <HBox spacing="10">
                        <Button text="Add User" onAction="#handleAddUser" styleClass="btn-primary" />
                        <Button text="Edit User" onAction="#handleEditUser" styleClass="button" />
                        <Button text="Delete User" onAction="#handleDeleteUser" styleClass="btn-danger" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button text="Reset Password" onAction="#handleResetPassword" styleClass="btn-warning" />
                        <Button text="Toggle Active" onAction="#handleToggleActive" styleClass="button" />
                    </HBox>
                </VBox>
            </Tab>
            
        </TabPane>
    </center>
</BorderPane>